# Production environment variables
# Copy to .env.production and fill in values

# Public site URL for SEO (metadataBase, sitemap, robots). No trailing slash.
# NEXT_PUBLIC_SITE_URL=https://forks-github.devliv.io

# GitHub API Token (personal access token with repo scope)
GITHUB_TOKEN=ghp_your_token_here

# Optional: GitHub API base URL (for GitHub Enterprise or self-hosted instances)
# GITHUB_BASE_URL=https://github.example.com/api/v3

# OpenAI API Key (for embeddings)
OPENAI_API_KEY=sk-your_key_here

# Google Gemini (deep fork analysis — Generative Language API)
GEMINI_API_KEY=

# Qdrant Vector Database
# For Docker Compose: http://qdrant:6333
# For Kubernetes: http://qdrant-service:6333
# For Qdrant Cloud: https://your-cluster.qdrant.io
QDRANT_URL=http://qdrant:6333

# Qdrant API key (optional, only for Qdrant Cloud)
QDRANT_API_KEY=

# PocketBase
# For Docker Compose: http://pocketbase:8090
# For external: https://your-pocketbase-domain.com
POCKETBASE_URL=http://pocketbase:8090

# Node environment
NODE_ENV=production

# Optional: Qdrant collection name
# QDRANT_COLLECTION=fork_chunks

# Optional: Enable debug logging
# DEBUG=github-forks:*
